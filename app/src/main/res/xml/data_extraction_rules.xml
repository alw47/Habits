<?xml version="1.0" encoding="utf-8"?>
<!--
    Data extraction rules for API 31+.
    The Room database and SharedPreferences are included in both
    cloud backup and device-to-device transfer by default.
    Diagnostic log files are excluded — they are device-specific
    and have no value in a backup or on a new device.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="logs/" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="logs/" />
    </device-transfer>
</data-extraction-rules>
