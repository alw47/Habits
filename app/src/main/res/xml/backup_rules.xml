<?xml version="1.0" encoding="utf-8"?>
<!--
    Auto-backup rules for API 30 and below.
    The Room database (databases/) and SharedPreferences (shared_prefs/)
    are backed up by default — no need to list them explicitly.
    Diagnostic log files are excluded because they are device-specific
    and have no value on a new device.
-->
<full-backup-content>
    <exclude domain="file" path="logs/" />
</full-backup-content>
